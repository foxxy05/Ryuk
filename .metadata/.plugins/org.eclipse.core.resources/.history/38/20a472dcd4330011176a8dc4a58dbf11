void KFS_Pick_Servo() {
	//GRIP
	if (circle) {
		is = true;
	}
	if (!circle && is) {
		is = false;
		count++;
	}

	if (count % 2 == 0) {
		// RELEASE!
		RotateServo(&PCA, 3, 60);	//RIGHT
		RotateServo(&PCA, 4, 160);	//LEFT
		checked = false;

	} else {
		// GRIP
		RotateServo(&PCA, 3, 160);	//RIGHT
		RotateServo(&PCA, 4, 60);	//LEFT

		checked = true;
	}

}

