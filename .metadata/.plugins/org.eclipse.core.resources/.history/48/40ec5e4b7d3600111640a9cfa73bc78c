	InitCytron(&Belt, &htim13, TIM_CHANNEL_1, GPIOF, GPIO_PIN_9, 1); // DIR PF9   PWM PF8

	rotate_motor(0, 0, 0);

	InitPCA(&PCA, &hi2c3, 50);
	STAFF_Init();

//	  if (ADS1115_Init(&hi2c1, ADS1115_DATA_RATE_128, ADS1115_PGA_TWOTHIRDS) == HAL_OK) {
//	      HAL_Delay(100);
//	  } else {
//	      Error_Handler();
//	  }

//	bno055_assignI2C(&hi2c1);
	bno055_assignI2C(&hfmpi2c1);
	bno055_setup();
	bno055_setOperationModeNDOF();

	currentHeading = 0;
	HAL_Delay(3000);

	/* USER CODE END 2 */

	/* Infinite loop */
	/* USER CODE BEGIN WHILE */
	while (1) {
		/* USER CODE END WHILE */

		/* USER CODE BEGIN 3 */

        process_data();
        STAFF_Motion();
        TurretMotor();
        BeltMotor();
        KFS_Pick_Servo();
        ConveyerMotor();
        M1_ODrive();
        Navigation();

        if (imu) {
            get_angle();
            imu = false;
        }

        if (PS4.Omega) {
            pid_enabled = false;
            flag        = true;
        }

        if (!PS4.Omega && flag) {
            flag          = false;
        //  HAL_Delay(200);
            pid_enabled   = true;
            targetHeading = currentHeading;
        }

        if (pid_enabled) HeadingPID();

        bool isZeroInput = (PS4.LX == 0 && PS4.LY == 0 && PS4.Omega == 0);

        if (nav_active) {
            move1(xPosition, yPosition,
                  waypoints[wp_idx].x, waypoints[wp_idx].y,
                  waypoints[wp_idx].heading);
            bool navZero = (pwm1 == 0 && pwm2 == 0 && pwm3 == 0);
            updateAllRamps(navZero);
        } else {
            find_wheel_vel();
            updateAllRamps(isZeroInput);
        }

        rotate_motor(ramp1, ramp2, ramp3);

        //  sprintf(msg, "ANGLE %.2f  LX %d  LY %d  pwm1 %d  pwm2 %d  pwm3 %d Omega %d\r\n",
        //          currentHeading, PS4.LX, PS4.LY, pwm1, pwm2, pwm3, PS4.Omega);
        //  HAL_UART_Transmit(&huart3, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

        HAL_Delay(10);
	}
	/* USER CODE END 3 */
