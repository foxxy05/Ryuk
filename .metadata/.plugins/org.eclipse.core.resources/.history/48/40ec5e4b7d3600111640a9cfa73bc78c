// ===================== RAMP =====================

float linear_ramp(float current, float target, bool isZeroInput) {
    float error = target - current;
    float step;

    if (isZeroInput) {
        step = RAMP_DOWN;
    } else {
        step = (fabs(target) < fabs(current)) ? RAMP_DOWN : RAMP_UP;
    }

    if (fabs(error) <= step || fabs(current) < STOP_THRESH)
        return target;

    return current + (error > 0 ? step : -step);
}

void updateAllRamps(bool isZeroInput) {
    ramp1 = linear_ramp(ramp1, (float)pwm1, isZeroInput);
    ramp2 = linear_ramp(ramp2, (float)pwm2, isZeroInput);
    ramp3 = linear_ramp(ramp3, (float)pwm3, isZeroInput);
}

