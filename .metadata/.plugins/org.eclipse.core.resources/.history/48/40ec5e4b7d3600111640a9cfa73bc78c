// ===================== KFS PICK =====================

float turretRampUpdate(float current, float target, bool noInput) {
    float error = target - current;
    float step;

    bool direction_change = (current > 0 && target < 0) || (current < 0 && target > 0);

    if (noInput)
        step = turretRamp_DOWN;
    else if (direction_change)
        step = turretRamp_DOWN * 1.5f;
    else
        step = (fabs(target) < fabs(current)) ? turretRamp_DOWN : turretRamp_UP;

    if (fabs(error) <= step || fabs(current) < TURRET_STOP_THRESH)
        return target;

    return current + (error > 0 ? step : -step);
}

void TurretMotor() {
    float target = 0;
    if      (PS4.right) target =  70;
    else if (PS4.left)  target = -70;

    bool noInput = (!PS4.right && !PS4.left);
    turretRamp   = turretRampUpdate(turretRamp, target, noInput);

    if (fabs(turretRamp) < 2.0f)
        StopCytron(&Turret);
    else
        RotateCytron(&Turret, (int)turretRamp);
}

void BeltMotor() {
    if      (PS4.up)   RotateCytron(&Belt,  90);
    else if (PS4.down) RotateCytron(&Belt, -90);
    else               StopCytron(&Belt);
}

void KFS_Pick_Servo() {
    if (PS4.circle)        is = true;
    if (!PS4.circle && is) { is = false; count++; }

    if (count % 2 == 0) {
        RotateServo(&PCA, 3, 160);   // RIGHT
        RotateServo(&PCA, 4,  60);   // LEFT
        checked = false;
    } else {
        RotateServo(&PCA, 3,  60);   // RIGHT
        RotateServo(&PCA, 4, 160);   // LEFT
        checked = true;
    }
}

void ConveyerMotor() {
    if      (PS4.L1) RotateMotor(&conveyer,  120);
    else if (PS4.R1) RotateMotor(&conveyer, -120);
    else             RotateMotor(&conveyer,    0);
}

// ===================== ODRIVE =====================

void M1_ODrive() {
    if (PS4.Touchpad && !ODrive.prevState) {
        ODrive.prevState = true;
        ODrivePos = (ODrivePos == REACH) ? HOME : REACH;
    } else if (!PS4.Touchpad) {
        ODrive.prevState = false;
    }

    if (PS4.Share && !ODrivePlace.prevState) {
        ODrivePlace.prevState = true;
        ODrivePos = (ODrivePos == PLACE) ? HOME : PLACE;
    } else if (!PS4.Share) {
        ODrivePlace.prevState = false;
    }

    switch (ODrivePos) {
    case HOME:  ODrive_goTo(&M1,  0.0f, 60.0f); break;
    case PLACE: ODrive_goTo(&M1,  6.0f, 60.0f); break;
    case REACH: ODrive_goTo(&M1, 48.0f, 60.0f); break;
    default:    ODrive_goTo(&M1,  0.0f,  0.0f); break;
    }
}

// ===================== POSITIONING (SICK) =====================

void get_current_coordinates() {
//  ADS1115_readSingleEnded(ADS1115_MUX_AIN0, &sick[0].CH_mV);
//  ADS1115_readSingleEnded(ADS1115_MUX_AIN1, &sick[1].CH_mV);
//  ADS1115_readSingleEnded(ADS1115_MUX_AIN2, &sick[2].CH_mV);

    for (int s = 0; s < SICK_COUNT; s++) {
        sick[s].voltage  = sick[s].CH_mV / 1000.0f;
        sick[s].distance = ((sick[s].voltage - sick[s].vOFFSET) / sick[s].vSPAN) * total_dis;
        sick[s].distanceINT = (int)sick[s].distance;
        sick[s].distanceDEC = (int)((sick[s].distance - sick[s].distanceINT) * 10);
    }
}

// ===================== AUTO NAVIGATION =====================

void move1(float x1, float y1, float x2, float y2, float finalHeading) {
    targetHeading   = finalHeading;
    targetDistance  = sqrt(pow(x1 - x2, 2) + pow(y1 - y2, 2));
    currentDistance = sqrt(pow(xPosition - x1, 2) + pow(yPosition - y1, 2));

    angle = atan2(y2 - yPosition, x2 - xPosition) - radians(targetHeading);

    float error = targetDistance - currentDistance;

    // Integral reset outside active tracking window
    if (fabs(error) < 0.5f || fabs(error) > targetDistance)
        pid_linear.I = 0.0f;

    PIDCompute(&pid_linear, error, dt2);
    vel = pid_linear.output;

    PWM1 = constrain(((vel * cos(angle) - (length * PS4.Omega))) / radius, -LINEAR_PWM, LINEAR_PWM);
    PWM2 = constrain(((sqrt(3) * vel * sin(angle) - vel * cos(angle) - 2 * length * PS4.Omega) / (2 * radius)), -LINEAR_PWM, LINEAR_PWM);
    PWM3 = constrain((-1 * ((vel * cos(angle) + sqrt(3) * vel * sin(angle) + 2 * length * PS4.Omega) / (2 * radius))), -LINEAR_PWM, LINEAR_PWM);

    pwm1 = constrain(PWM1 + CORRECTION, -MAX_PWM, MAX_PWM);
    pwm2 = constrain(PWM2 + CORRECTION, -MAX_PWM, MAX_PWM);
    pwm3 = constrain(PWM3 + CORRECTION, -MAX_PWM, MAX_PWM);

//  pwm1 = constrain(CORRECTION,       -MAX_PWM, MAX_PWM);
//  pwm2 = constrain(CORRECTION - 40,  -MAX_PWM, MAX_PWM);
//  pwm3 = constrain(CORRECTION + 40,  -MAX_PWM, MAX_PWM);

    if (fabs(error) < 2.0f) {
        reached    = true;
        navActive = false;
    }
}

bool NavPressed = false;

void Navigation() {
    if (PS4.cross && !NavPressed) {
        NavPressed = true;
        if (!navActive) {
            wp_idx++;
            if (wp_idx < (int)WAYPOINT_COUNT) {
                reached        = false;
                navActive     = true;
                targetHeading  = WayPoints[wp_idx].heading;
            }
        }
    } else if (!PS4.cross) {
        NavPressed = false;
    }
}

