// ===================== PID =====================

/*
 * Generic PID compute.
 * Caller is responsible for passing a valid deltaT (dt2).
 * Integral reset logic is handled by the caller (e.g. pid_heading).
 * Returns the PID output and also stores it in pid->output.
 */
float PIDCompute(PID_t *pid, float error, float deltaT) {
    float d_error = error - pid->prev_error;
    pid->prev_error = error;

    pid->P = error * pid->kp;
    pid->D = (deltaT > 1e-6f) ? ((d_error / deltaT) * pid->kd) : 0.0f;
    pid->I = pid->I + (error * deltaT * pid->ki);

    pid->output = pid->P + pid->I + pid->D;
    return pid->output;
}

void HeadingPID() {
    float err = normalise_angle(targetHeading - currentHeading);

    // Integral reset: outside deadband or inside settled threshold
    if (fabs(err) > 3.5f || fabs(err) < 0.5f)
        pid_heading.I = 0.0f;

    PIDCompute(&pid_heading, err, dt2);
    CORRECTION = pid_heading.output;
}

// ===================== PS4 INPUT =====================

void process_data() {
//  HAL_I2C_Master_Receive(&hi2c1, SLAVE_ADDR << 1, (uint8_t*)data, DATA_SIZE, HAL_MAX_DELAY);
    int8_t data[DATA_SIZE];
    HAL_UART_Receive(&huart4, (uint8_t*)data, sizeof(data), HAL_MAX_DELAY);

    uint8_t TempData1 = data[1];
    uint8_t TempData2 = data[2];

    PS4.up       = (TempData1 & (1 << 0)) ? 1 : 0;
    PS4.right    = (TempData1 & (1 << 1)) ? 1 : 0;
    PS4.down     = (TempData1 & (1 << 2)) ? 1 : 0;
    PS4.left     = (TempData1 & (1 << 3)) ? 1 : 0;
    PS4.triangle = (TempData1 & (1 << 4)) ? 1 : 0;
    PS4.circle   = (TempData1 & (1 << 5)) ? 1 : 0;
    PS4.cross    = (TempData1 & (1 << 6)) ? 1 : 0;
    PS4.square   = (TempData1 & (1 << 7)) ? 1 : 0;

    PS4.L1      = (TempData2 & (1 << 0)) ? 1 : 0;
    PS4.R1      = (TempData2 & (1 << 1)) ? 1 : 0;
    PS4.L3      = (TempData2 & (1 << 2)) ? 1 : 0;
    PS4.R3      = (TempData2 & (1 << 3)) ? 1 : 0;
    PS4.Share   = (TempData2 & (1 << 4)) ? 1 : 0;
    PS4.Options = (TempData2 & (1 << 5)) ? 1 : 0;
    PS4.Touchpad= (TempData2 & (1 << 6)) ? 1 : 0;
    PS4.PS      = (TempData2 & (1 << 7)) ? 1 : 0;

    PS4.Omega        = -data[7];
    PS4.RY =  data[6];
    PS4.RX =  data[5];
    PS4.LX =  data[3];
    PS4.LY =  data[4];

    if (abs(PS4.LX) < DEADZONE) PS4.LX = 0;
    if (abs(PS4.LY) < DEADZONE) PS4.LY = 0;
    if (abs(PS4.Omega)        < 5)        PS4.Omega         = 0;

    PS4.Omega = (int)map((float)PS4.Omega, -127.0f, 127.0f, -50.0f, 50.0f);
}

// ===================== MANUAL DRIVE =====================

void find_wheel_vel() {
    bot_vel = sqrt(pow(PS4.LX, 2) + pow(PS4.LY, 2));
    theta   = atan2(PS4.LY, PS4.LX) + radians(targetHeading);

    pwm1 = constrain(
               ((bot_vel * cos(theta) - (length * PS4.Omega)) / radius) + CORRECTION,
               -MAX_PWM, MAX_PWM) * PWM_MULTIPLIER;
    pwm2 = constrain(
               ((sqrt(3) * bot_vel * sin(theta) - bot_vel * cos(theta)
                 - 2 * length * PS4.Omega) / (2 * radius)) + CORRECTION,
               -MAX_PWM, MAX_PWM) * PWM_MULTIPLIER;
    pwm3 = constrain(
               (-1 * ((bot_vel * cos(theta) + sqrt(3) * bot_vel * sin(theta)
                       + 2 * length * PS4.Omega) / (2 * radius))) + CORRECTION,
               -MAX_PWM, MAX_PWM) * PWM_MULTIPLIER;
}

