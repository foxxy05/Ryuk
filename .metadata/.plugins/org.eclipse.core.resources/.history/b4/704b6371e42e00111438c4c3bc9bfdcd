     void PID2(){

     	  ERR = normalise_angle(target_heading - current_heading);
     	   D_error = ERR - ERR2;
     	   ERR2 = ERR;

     	  p = ERR*KP;
     	  i = i + (ERR*(float)dt2*KI);
     	  d = (D_error/(float)dt2)*KD;

     	  CORRECTION = p+i+d;


       }

     void get_enc_value(){

    //        timer_counter1 = __HAL_TIM_GET_COUNTER(&htim1);
    //      	timer_counter2 = __HAL_TIM_GET_COUNTER(&htim2);
    //      	timer_counter3 = __HAL_TIM_GET_COUNTER(&htim3);

          	update_encoder(&L_enc, &htim1);
          	update_encoder(&R_enc, &htim2);
          	update_encoder(&F_enc, &htim3);

          	double trueTheta = radians(current_heading);

          	  // IMU DELTA THETA
          	  double delTheta = trueTheta - prevTheta;

          	  if (delTheta > PI)  {
          	      delTheta -= 2 * PI;
          	  }

          	  if (delTheta < -PI) {
          	      delTheta += 2 * PI;
          	  }

          	  double midTheta = prevTheta + ( delTheta / 2.0 );

          	  // ENCODER READ
          	  FCount = F_enc.position;
          	  LCount = L_enc.position;
    //      	  RCount = R_enc.position;
          	  RCount = 0;

          	  dF = FCount - prevFCount;
          	  dL = LCount - prevLCount;
          	  dR = RCount - prevRCount;

          	  // TRANSLATION
          	  deltaX = ( dF / CPR) * 2 * PI * WHEEL_RADIUS * 650.0/625.0;
          	  //deltaY = (((dL + dR) / 2.0 )/ CPR) * 2 * PI * RADIUS;
          	  deltaY = ( dL / CPR) * 2 * PI * WHEEL_RADIUS * 650.0/620.0;
           	 xPosition += deltaX;
           	 yPosition -= deltaY;

           	 prevFCount = FCount;
           	 prevLCount = LCount;
           	 prevRCount = RCount;
           	 prevTheta  = trueTheta;
     }

