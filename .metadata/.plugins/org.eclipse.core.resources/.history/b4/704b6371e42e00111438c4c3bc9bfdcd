	}

}

typedef struct{
	bool prevState;
	bool flag;
}ToggleButton;

ToggleButton StaffGripServo = { 0 };
ToggleButton StaffAttackServo = { 0 };

void STAFF_Servo(){
	// GRIP SERVO
	if(square && !StaffGripServo.prevState){
		StaffGripServo.prevState = true;
		StaffGripServo.flag 		= !StaffGripServo.flag;

		if(StaffGripServo.flag){
//			RotateServo(&PCA, GRIP_SERVO_1, GRIP_SERVO_1_GRIP_ANGLE);
//			RotateServo(&PCA, 8, 90);
			RotateServo(&PCA, 11, 90);
			RotateServo(&PCA, 3, 90);
		}
		else{
//			RotateServo(&PCA, GRIP_SERVO_1, GRIP_SERVO_1_RELEASE_ANGLE);
//			RotateServo(&PCA, 8, 150);
			RotateServo(&PCA, 11, 150);
			RotateServo(&PCA, 3, 150);
		}
	}
	else if (!square){
		StaffGripServo.prevState = false;
	}

	// ATTACK SERVO
	if(triangle && !StaffAttackServo.prevState){
		StaffAttackServo.prevState = true;
		StaffAttackServo.flag 	   = !StaffAttackServo.flag;

		if(StaffAttackServo.flag){
//			RotateServo(&PCA, ATTACK_SERVO_1, ATTACK_SERVO_1_ATTACK_ANGLE);
			RotateServo(&PCA, 12, 110);
			RotateServo(&PCA, 10, 15);
			RotateServo(&PCA, 2, 67);
		}
		else{
//			RotateServo(&PCA, ATTACK_SERVO_1, ATTACK_SERVO_1_NORMAL_ANGLE);
			RotateServo(&PCA, 12, 110+47);
			RotateServo(&PCA, 10, 58);
			RotateServo(&PCA, 2, 110);
		}
	}
	else if(!triangle){
		StaffAttackServo.prevState = false;
	}
}

void STAFF_Motion(){
	STAFF_Motor();
	STAFF_Servo();
}

void TurretMotor(){
	if(right){
		RotateCytron(&Turret, 50);
	}
	else if(left){
		RotateCytron(&Turret, -50);
	}
	else{
		StopCytron(&Turret);
	}
}

void BeltMotor(){
	if(up){
		RotateCytron(&Belt, 50);
	}
	else if(down){
		RotateCytron(&Belt, -50);
	}
	else{
		StopCytron(&Belt);
	}
}

ToggleButton KFSPickServo = { 0 };

void KFS_Pick_Servo(){
	// GRIP SERVO
	if(circle && !KFSPickServo.prevState){
		KFSPickServo.prevState = true;
		KFSPickServo.flag 		= !KFSPickServo.flag;

		if(KFSPickServo.flag){
			RotateServo(&PCA, 7, 60);	//RIGHT
			RotateServo(&PCA, 4, 160);	//LEFT
		}
		else{
			RotateServo(&PCA, 7, 160);	//RIGHT
			RotateServo(&PCA, 4, 60);	//LEFT
		}
	}
	else if (!circle){
		KFSPickServo.prevState = false;
	}
}

