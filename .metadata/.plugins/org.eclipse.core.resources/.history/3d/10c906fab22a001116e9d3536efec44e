void Move(float x1, float y1, float x2, float y2)
{
    //  botVel   = sqrt(pow(Joystick.LX, 2) + pow(Joystick.LY, 2));
    //  navAngle = atan2(Joystick.LY, Joystick.LX) - Radians(targetHeading);

    float targetDistanceY  = y2 - y1;
    float targetDistanceX  = x2 - x1;

    float currentDistanceY = Odo.yPosition - y1;
    float currentDistanceX = Odo.xPosition - x1;

    //  navAngle = atan2(y2 - Odo.yPosition, x2 - Odo.xPosition) - Radians(targetHeading);

    if (dt2 <= 0.0f) dt2 = 0.001f;

    yPID.error = targetDistanceY - currentDistanceY;
    xPID.error = targetDistanceX - currentDistanceX;

    // ki activation — windup guard, only engage near target
    yPID.kiActive = (fabs(yPID.error) < 5) ? KI_ACTIVE : KI_INACTIVE;
    xPID.kiActive = (fabs(xPID.error) < 5) ? KI_ACTIVE : KI_INACTIVE;

    LinearPIDCompute(&yPID, dt2);
    LinearPIDCompute(&xPID, dt2);

    navAngle = atan2f(yPID.controlSignal, xPID.controlSignal) - Radians(targetHeading);
    botVel   = sqrtf(powf(yPID.controlSignal, 2) + powf(xPID.controlSignal, 2));

    float PWM1 = constrain( (botVel * cosf(navAngle) - (length * omega)) / radius,                                                  -LINEAR_PWM, LINEAR_PWM);
    float PWM2 = constrain( (sqrtf(3) * botVel * sinf(navAngle) - botVel * cosf(navAngle) - 2 * length * omega) / (2 * radius),     -LINEAR_PWM, LINEAR_PWM);
    float PWM3 = constrain( -1 * (botVel * cosf(navAngle) + sqrtf(3) * botVel * sinf(navAngle) + 2 * length * omega) / (2 * radius), -LINEAR_PWM, LINEAR_PWM);

    pwmM1 = (int)constrain(PWM1 + AngPID.controlSignal, -MAX_PWM, MAX_PWM);
    pwmM2 = (int)constrain(PWM2 + AngPID.controlSignal, -MAX_PWM, MAX_PWM);
    pwmM3 = (int)constrain(PWM3 + AngPID.controlSignal, -MAX_PWM, MAX_PWM);

    //  pwmM1 = constrain(AngPID.controlSignal,      -MAX_PWM, MAX_PWM);
    //  pwmM2 = constrain(AngPID.controlSignal - 40, -MAX_PWM, MAX_PWM);
    //  pwmM3 = constrain(AngPID.controlSignal + 40, -MAX_PWM, MAX_PWM);

    if (fabs(yPID.error) < 5 && fabs(xPID.error) < 5)
    {
        reached = true;
        //  RotateMotors(0, 0, 0);
    }

    //  spitf("x = %.2f   y = %.2f target = %.2f  current = %.2f error = %.2f angle = %.2f \r\n",
    //         Odo.xPosition, Odo.yPosition, targetDistanceY, currentDistanceY, yPID.error, Degrees(navAngle));
}
