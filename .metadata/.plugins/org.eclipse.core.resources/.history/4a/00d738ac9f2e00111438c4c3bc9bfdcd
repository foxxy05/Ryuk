void STAFF_Motor(){
	if(R_joystick_y){
		int16_t beltSpeed = (int16_t)constrain(R_joystick_y, -MAX_STAFF_PWM, MAX_STAFF_PWM);
//		RotateMotor(&STAFF_MOTOR, beltSpeed);		//BTS
		RotateCytron(&STAFF_MOTOR, beltSpeed);
	}
	else{
//		StopMotor(&STAFF_MOTOR);		// BTS
		StopCytron(&STAFF_MOTOR);
	}
}

