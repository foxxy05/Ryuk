uint8_t RxData[8];
uint32_t blink_delay;

float radians(float angle) {
	return angle * 2 * 3.14 / 360.0;
}

float degrees(float angle) {
	return angle * 360.0 / (2 * 3.14);
}

float map(float x, float in_min, float in_max, float out_min, float out_max) {
	return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

float constrain(float num, float min, float max) {

	if (num > max)
		return max;
	else if (num < min)
		return min;
	else
		return num;
}

float normalise_angle(float angle) {
	if (angle > 180.0)			angle -= 360.0;
	if (angle < -180.0)			angle += 360.0;

	return angle;
}

void get_angle() {
	bno055_vector_t v = bno055_getVectorEuler();
	IMU.current = v.x;
}

void processData() {
	HAL_UART_Receive(&huart4, (uint8_t*) data, sizeof(data), HAL_MAX_DELAY);
	uint8_t TempData1 = data[1];
	uint8_t TempData2 = data[2];

	PS4.Up 			= ((TempData1 & (1 << 0)) ? 1 : 0);
	PS4.Right 		= ((TempData1 & (1 << 1)) ? 1 : 0);
	PS4.Down 		= ((TempData1 & (1 << 2)) ? 1 : 0);
	PS4.Left 		= ((TempData1 & (1 << 3)) ? 1 : 0);
	PS4.Triangle 	= ((TempData1 & (1 << 0)) ? 1 : 0);
	PS4.Circle 		= ((TempData1 & (1 << 1)) ? 1 : 0);
	PS4.Cross 		= ((TempData1 & (1 << 2)) ? 1 : 0);
	PS4.Square 		= ((TempData1 & (1 << 3)) ? 1 : 0);

	PS4.L1 			= ((TempData2 & (1 << 0)) ? 1 : 0);
	PS4.R1 			= ((TempData2 & (1 << 1)) ? 1 : 0);
	PS4.L3 			= ((TempData2 & (1 << 2)) ? 1 : 0);
	PS4.R3 			= ((TempData2 & (1 << 3)) ? 1 : 0);
	PS4.Share 		= ((TempData2 & (1 << 4)) ? 1 : 0);
	PS4.Options 	= ((TempData2 & (1 << 5)) ? 1 : 0);
	PS4.Touchpad 	= ((TempData2 & (1 << 6)) ? 1 : 0);
	PS4.PS 			= ((TempData2 & (1 << 7)) ? 1 : 0);

	PS4.Omega		= -data[7];
	PS4.RY			= data[6];
	PS4.RX			= data[5];
	PS4.LX			= data[3];
	PS4.LY			= data[4];

	if(abs(PS4.LX) < DEADZONE)			PS4.LX = 0;
	if(abs(PS4.LY) < DEADZONE)			PS4.LY = 0;
	if(abs(PS4.Omega) < 5)				PS4.Omega = 0;

	PS4.Omega		= map(PS4.Omega. -127, 127, -OMEGA_LIMIT, OMEGA_LIMIT);
}

