/* ========== ANGULAR PID ========== */

void AngularPIDCompute(void)
{
    ERR     = NormaliseAngle(target_heading - current_heading);
    D_error = ERR - ERR2;
    ERR2    = ERR;

    angPID.p = ERR * angPID.kp;
    angPID.i = angPID.i + (ERR * dt2 * angPID.ki);
    angPID.d = (D_error / dt2) * angPID.kd;

    CORRECTION = angPID.p + angPID.i + angPID.d;
}

