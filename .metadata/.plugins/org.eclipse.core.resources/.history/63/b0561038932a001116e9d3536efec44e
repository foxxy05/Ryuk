/* ========== NAVIGATION ========== */

void Move(float x1, float y1, float x2, float y2)
{
    target_distance_y  = y2 - y1;
    target_distance_x  = x2 - x1;

    current_distance_y = yPosition - y1;
    current_distance_x = xPosition - x1;

    // angle = atan2(y2 - yPosition, x2 - xPosition) - radians(target_heading);

    error_y   = target_distance_y - current_distance_y;
    error_x   = target_distance_x - current_distance_x;

    d_error_y = error_y - error2_y;
    d_error_x = error_x - error2_x;

    error2_y  = error_y;
    error2_x  = error_x;

    // conditional ki: only engage integral in the last 5 cm to reduce overshoot
    yPID.ki = (fabsf(error_y) < 5) ? 0.75f : 0.0f;
    xPID.ki = (fabsf(error_x) < 5) ? 0.75f : 0.0f;

    yPID.p = error_y * yPID.kp;
    xPID.p = error_x * xPID.kp;
    yPID.i = yPID.i + (error_y * dt2 * yPID.ki);
    xPID.i = xPID.i + (error_x * dt2 * xPID.ki);
    yPID.d = (d_error_y / dt2) * yPID.kd;
    xPID.d = (d_error_x / dt2) * xPID.kd;

    vel_y = -(yPID.p + yPID.i + yPID.d);
    vel_x = -(xPID.p + xPID.i + xPID.d);

    angle = atan2(vel_y, vel_x) - radians(target_heading);
    vel   = sqrtf(powf(vel_y, 2) + powf(vel_x, 2));

    PWM1 = constrain(((vel * cos(angle) - (length * omega))) / radius,                                       -LINEAR_PWM, LINEAR_PWM);
    PWM2 = constrain(((sqrt(3) * vel * sin(angle) - vel * cos(angle) - 2 * length * omega) / (2 * radius)), -LINEAR_PWM, LINEAR_PWM);
    PWM3 = constrain((-1 * ((vel * cos(angle) + sqrt(3) * vel * sin(angle) + 2 * length * omega) / (2 * radius))), -LINEAR_PWM, LINEAR_PWM);

    pwm1 = (int)constrain(PWM1 + CORRECTION, -MAX_PWM, MAX_PWM);
    pwm2 = (int)constrain(PWM2 + CORRECTION, -MAX_PWM, MAX_PWM);
    pwm3 = (int)constrain(PWM3 + CORRECTION, -MAX_PWM, MAX_PWM);

    // pwm1 = (int)constrain(CORRECTION,      -MAX_PWM, MAX_PWM);
    // pwm2 = (int)constrain(CORRECTION - 40, -MAX_PWM, MAX_PWM);
    // pwm3 = (int)constrain(CORRECTION + 40, -MAX_PWM, MAX_PWM);

    if (fabsf(error_y) < 5 && fabsf(error_x) < 5)
    {
        reached = true;
        // RotateMotors(0, 0, 0);
    }

    // spitf("x = %.2f y = %.2f target = %.2f current = %.2f error = %.2f angle = %.2f \r\n",
    //       xPosition, yPosition, target_distance_y, current_distance_y, error_y, degrees(angle));
}

