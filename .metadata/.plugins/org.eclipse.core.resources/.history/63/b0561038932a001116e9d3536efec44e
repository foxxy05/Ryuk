/* ========== MATH HELPERS ========== */

float radians(float angle)
{
    return angle * 2 * PI / 360.0f;
}

float degrees(float angle)
{
    return angle * 360.0f / (2 * PI);
}

long map(long x, long in_min, long in_max, long out_min, long out_max)
{
    return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

float constrain(float num, float min, float max)
{
    if      (num > max) return max;
    else if (num < min) return min;
    else                return num;
}

/* ========== BNO055 ========== */

void BNO055_Init(void)
{
    uint8_t pwr    = 0x00;
    uint8_t opr    = 0x0C;
    uint8_t config = 0x00;

    HAL_I2C_Mem_Write(&hi2c1, BNO055_ADDR, OPR_MODE, 1, &config, 1, 100); // setting to config mode
    HAL_I2C_Mem_Write(&hi2c1, BNO055_ADDR, PWR_MODE, 1, &pwr,    1, 100); // setting bno055 to normal mode
    HAL_I2C_Mem_Write(&hi2c1, BNO055_ADDR, OPR_MODE, 1, &opr,    1, 100); // setting to Ndof mode

    HAL_Delay(700);
}

float NormaliseAngle(float angle)
{
    if (angle >  180.0f) angle -= 360.0f;
    if (angle < -180.0f) angle += 360.0f;
    return angle;
}

