float degree2radian(float angle) {
    return angle * ((float)PI / 180.0f);
}

float radian2degree(float angle) {
    return angle * (180.0f / (float)PI);
}

void EncodersInit(void) {
    HAL_TIM_Encoder_Start(&ENCODER_F_TIM, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&ENCODER_L_TIM, TIM_CHANNEL_ALL);
    HAL_TIM_Encoder_Start(&ENCODER_R_TIM, TIM_CHANNEL_ALL);
    resetEncoder(&FEnc);
    resetEncoder(&LEnc);
    resetEncoder(&REnc);
}

void EncodersUpdate(void) {
    updateEncoder(&FEnc, &ENCODER_F_TIM);
    updateEncoder(&LEnc, &ENCODER_L_TIM);
    updateEncoder(&REnc, &ENCODER_R_TIM);
}

void OdometryInit(Odometry_t *Odo) {
    EncodersInit();
    Odo->prevF         = FEnc.position;
    Odo->prevL         = LEnc.position;
    Odo->prevR         = REnc.position;
    Odo->xPosition     = 0.0;
    Odo->yPosition     = 0.0;
    Odo->thetaPosition = 0.0;
    Odo->prevTheta     = 0.0;
}

void OdometryUpdate(Odometry_t *Odo) {
    EncodersUpdate();

    long FCount = FEnc.position;
    long LCount = LEnc.position;
    long RCount = REnc.position;

    long dF = FCount - Odo->prevF;
    long dL = LCount - Odo->prevL;
    long dR = RCount - Odo->prevR;

    double wheelBase = 2.0 * PARALLEL_OFFSET;
    double deltaL    = ((double)dL / CPR) * 2.0 * PI * WHEEL_RADIUS;
    double deltaR    = ((double)dR / CPR) * 2.0 * PI * WHEEL_RADIUS;
    double delTheta  = (deltaR - deltaL) / wheelBase;

    if (delTheta >  PI) delTheta -= 2.0 * PI;
    if (delTheta < -PI) delTheta += 2.0 * PI;

    double midTheta = Odo->prevTheta + delTheta * 0.5;

    double deltaX = ((double)dF / CPR) * 2.0 * PI * WHEEL_RADIUS;
    double deltaY = (deltaL + deltaR) * 0.5;

    deltaX += delTheta * PERPENDICULAR_OFFSET;
    deltaY -= delTheta * PARALLEL_OFFSET;

    double dxG = deltaX * cos(midTheta) - deltaY * sin(midTheta);
    double dyG = deltaX * sin(midTheta) + deltaY * cos(midTheta);

    Odo->xPosition     += dxG;
    Odo->yPosition     += dyG;
    Odo->thetaPosition += delTheta;

    if (Odo->thetaPosition >  PI) Odo->thetaPosition -= 2.0 * PI;
    if (Odo->thetaPosition < -PI) Odo->thetaPosition += 2.0 * PI;

    Odo->prevF     = FCount;
    Odo->prevL     = LCount;
    Odo->prevR     = RCount;
    Odo->prevTheta = Odo->thetaPosition;
}

void PrintOdometry(Odometry_t *Odo) {
    int len = sprintf(txBuf, "X:%7.4f m  Y:%7.4f m  T:%7.2f deg  |  F:%6ld  L:%6ld  R:%6ld\r\n", Odo->xPosition, Odo->yPosition, radian2degree((float)Odo->thetaPosition), FEnc.position, LEnc.position, REnc.position
    );
    CDC_Transmit_FS((uint8_t*)txBuf, (uint16_t)len);
}

