void KFSODrive() {
	if (PS4.Touchpad && !ODrive.prevState) {
		ODrive.prevState = true;

		if (ODrivePos == REACH) {
			ODrivePos = HOME;
		} else {
			ODrivePos = REACH;
		}

	} else if (!PS4.Touchpad) {
		ODrive.prevState = false;
	}

	if (PS4.Share && !ODrivePlace.prevState) {
		ODrivePlace.prevState = true;

		if (ODrivePos == PLACE) {
			ODrivePos = HOME;
		} else {
			ODrivePos = PLACE;
		}

	} else if (!PS4.Share) {
		ODrivePlace.prevState = false;
	}

	switch (ODrivePos) {
	case HOME:
		ODrive_goTo(&M1, 0.0f, 60.0f);
		break;
	case PLACE:
		ODrive_goTo(&M1, 6.0f, 60.0f);
		break;
	case REACH:
		ODrive_goTo(&M1, 48.0f, 60.0f);
		break;
	default:
		ODrive_goTo(&M1, 0.0f, 00);
		break;
	}
}

