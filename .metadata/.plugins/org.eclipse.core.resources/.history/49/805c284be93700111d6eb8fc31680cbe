	MX_TIM11_Init();
	MX_TIM13_Init();
	MX_UART4_Init();
	MX_FMPI2C1_Init();
	/* USER CODE BEGIN 2 */

	M1.huart = &huart3;
	//  ODrive_clearErrors(&M1);

	// === Timers ===
	HAL_TIM_Base_Start_IT(&htim7);

	// === Motor ===
	InitBTS(&Conveyer, &htim9, TIM_CHANNEL_1, &htim9, TIM_CHANNEL_2, 2, 1000);
	InitCytron(&m1, &htim11, TIM_CHANNEL_1, GPIOF, GPIO_PIN_6, 1); // DIR PF6   PWM PF7
	InitCytron(&m2, &htim4, TIM_CHANNEL_2, GPIOD, GPIO_PIN_12, 1); // DIR PD12  PWM PD13
	InitCytron(&m3, &htim4, TIM_CHANNEL_4, GPIOD, GPIO_PIN_14, 0); // DIR PD14  PWM PD15
	InitCytron(&SM1, &htim8, TIM_CHANNEL_1, GPIOA, GPIO_PIN_3, 1); // DIR PA3   PWM PC6
	InitCytron(&Turret, &htim5, TIM_CHANNEL_2, GPIOA, GPIO_PIN_2, 0); // DIR PA2   PWM PA1
	InitCytron(&Belt, &htim13, TIM_CHANNEL_1, GPIOF, GPIO_PIN_9, 1); // DIR PF9   PWM PF8
	ChassiMotorsRotate(0, 0, 0);

	// ── Servo Init ────────────────────────────────────────────────────────────
	InitPCA(&PCA, &hi2c3, 50);
	STAFF_Init();

	// === ADS1115 Init ===
	if (ADS1115_Init(&hi2c1, ADS1115_DATA_RATE_128, ADS1115_PGA_TWOTHIRDS)
			== HAL_OK) {
		int len = sprintf(dbgMsg, "ADS1115 INIT OK\r\n");
		HAL_UART_Transmit(&huart3, (uint8_t*) dbgMsg, len, HAL_MAX_DELAY);
	} else {
		int len = sprintf(dbgMsg, "ADS1115 INIT FAILED\r\n");
		HAL_UART_Transmit(&huart3, (uint8_t*) dbgMsg, len, HAL_MAX_DELAY);
		Error_Handler();
	}

	// === IMU Init ===
	//  bno055_assignI2C(&hi2c1);
	bno055_assignI2C(&hfmpi2c1);
	bno055_setup();
	bno055_setOperationModeNDOF();

	IMU.current = 0.0f;
	IMU.target = 0.0f;

	HAL_Delay(3000);
	tickEnd = HAL_GetTick();

	/* USER CODE END 2 */

	/* Infinite loop */
	/* USER CODE BEGIN WHILE */
	while (1) {
		/* USER CODE END WHILE */

		/* USER CODE BEGIN 3 */
		tickStart = HAL_GetTick();
		dT = (tickStart - tickEnd) / 1000.0f;
		tickEnd = tickStart;

		processData();
		if (IMU.IMUready) {
			get_angle();
			IMU.IMUready = false;
		}

		//  Subsystems
		STAFF_Motion();
		KFS_PICK_Motion();

		//  Chassis
		if (Nav.active) {
			NavigateTo();

		} else {
			bool isZeroInput = (PS4.LX == 0 && PS4.LY == 0 && PS4.Omega == 0);

			if (PS4.Omega) {
				pidActive = false;
				omegaWasOn = true;
			}

			if (!PS4.Omega && omegaWasOn) {
				omegaWasOn = false;
				HAL_Delay(200);
				pidActive = true;
				IMU.target = IMU.current;
			}

			if (pidActive) {
				AngularPIDCompute();
			}

			velocityCompute();
			updateChassisRamps(isZeroInput);
			ChassiMotorsRotate((int) ChassisRamp.ch1, (int) ChassisRamp.ch2, (int) ChassisRamp.ch3);
		}

		//  Nav Button
		handleNavButton();
		HAL_Delay(10);

		/* USER CODE END 3 */
	}

