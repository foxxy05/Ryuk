void processData() {
	HAL_UART_Receive(&huart4, (uint8_t*) data, sizeof(data), HAL_MAX_DELAY);
	uint8_t TempData1 = data[1];
	uint8_t TempData2 = data[2];

	PS4.Up = ((TempData1 & (1 << 0)) ? 1 : 0);
	PS4.Right = ((TempData1 & (1 << 1)) ? 1 : 0);
	PS4.Down = ((TempData1 & (1 << 2)) ? 1 : 0);
	PS4.Left = ((TempData1 & (1 << 3)) ? 1 : 0);
	PS4.Triangle = ((TempData1 & (1 << 4)) ? 1 : 0);
	PS4.Circle = ((TempData1 & (1 << 5)) ? 1 : 0);
	PS4.Cross = ((TempData1 & (1 << 6)) ? 1 : 0);
	PS4.Square = ((TempData1 & (1 << 7)) ? 1 : 0);

	PS4.L1 = ((TempData2 & (1 << 0)) ? 1 : 0);
	PS4.R1 = ((TempData2 & (1 << 1)) ? 1 : 0);
	PS4.L3 = ((TempData2 & (1 << 2)) ? 1 : 0);
	PS4.R3 = ((TempData2 & (1 << 3)) ? 1 : 0);
	PS4.Share = ((TempData2 & (1 << 4)) ? 1 : 0);
	PS4.Options = ((TempData2 & (1 << 5)) ? 1 : 0);
	PS4.Touchpad = ((TempData2 & (1 << 6)) ? 1 : 0);
	PS4.PS = ((TempData2 & (1 << 7)) ? 1 : 0);

	PS4.Omega = -data[7];
	PS4.RY = data[6];
	PS4.RX = data[5];
	PS4.LX = data[3];
	PS4.LY = data[4];

	if (abs(PS4.LX) < DEADZONE)
		PS4.LX = 0;
	if (abs(PS4.LY) < DEADZONE)
		PS4.LY = 0;
	if (abs(PS4.Omega) < 5)
		PS4.Omega = 0;

	PS4.Omega = map(PS4.Omega, -127, 127, -OMEGA_LIMIT, OMEGA_LIMIT);
}

void velocityCompute() {
	float vel = sqrtf(powf(PS4.LX, 2) + powf(PS4.LY, 2));
	float angle = atan2f(PS4.LY, PS4.LX) + radians(IMU.target);

	float M1 = ((vel * cosf(angle) - (CHASSIS_LENGTH * PS4.Omega))
			/ CHASSIS_RADIUS) + AngularPID.Output;
	float M2 = ((sqrtf(3) * vel * sinf(angle) - vel * cosf(angle)
			- (2 * CHASSIS_LENGTH * PS4.Omega)) / (2 * CHASSIS_RADIUS))
			+ AngularPID.Output;
	float M3 = (-1
			* ((vel * cosf(angle) + sqrtf(3) * vel * sinf(angle)
					+ (2 * CHASSIS_LENGTH * PS4.Omega)) / (2 * CHASSIS_RADIUS)))
			+ AngularPID.Output;

	ChassisCmd.pwm1 = (int) constrain(M1, -MAX_PWM, MAX_PWM) * PWM_MULTIPLIER;
	ChassisCmd.pwm2 = (int) constrain(M2, -MAX_PWM, MAX_PWM) * PWM_MULTIPLIER;
	ChassisCmd.pwm3 = (int) constrain(M3, -MAX_PWM, MAX_PWM) * PWM_MULTIPLIER;
}

void ChassiMotorsRotate(int pwm1, int pwm2, int pwm3) {
	RotateCytron(&m1, pwm1);
	RotateCytron(&m2, pwm2);
	RotateCytron(&m3, pwm3);

}

void AngularPIDCompute() {
	AngularPID.error = normaliseAngle(IMU.target - IMU.current);
	float deltaError = AngularPID.error - AngularPID.prev_error;

	if (fabs(AngularPID.error) < INTEGRAL_THRESHOLD) {
		AngularPID.I += AngularPID.error * dT * AngularPID.ki;
	} else {
		AngularPID = 0;
	}

	if (dT > 0.0f) {
		AngularPID.D = (deltaError / dT) * AngularPID.kd;
	} else {
		AngularPID.D = 0.0f;
	}

	AngularPID.Output = constrain(AngularPID.P + AngularPID.I + AngularPID.D,
			-PID_CONSTRAIN, PID_CONSTRAIN);
}

