float linearRamp(float current, float target, bool isZeroInput) {
	float error = target - current;
	float step;

	if (isZeroInput) {
		step = CHASSIS_RAMP_DOWN;
	} else {
		if (fabs(target) < fabs(current)) {
			step = CHASSIS_RAMP_DOWN;
		} else {
			step = CHASSIS_RAMP_UP;
		}
	}

	if (fabs(error) <= step || fabs(current) < STOP_THRESH) {
		return target;
	}

	return current + (error > 0 ? step : -step);
}

void updateChassisRamps(bool isZeroInput) {
	ChassisRamp.ch1 = linearRamp(ChassisRamp.ch1, (float) ChassisCmd.pwm1,
			isZeroInput);
	ChassisRamp.ch2 = linearRamp(ChassisRamp.ch2, (float) ChassisCmd.pwm2,
			isZeroInput);
	ChassisRamp.ch3 = linearRamp(ChassisRamp.ch3, (float) ChassisCmd.pwm3,
			isZeroInput);
}

void getCurrentCoordinates() {
	int dist_int0, dist_dec0;
	int dist_int1, dist_dec1;
	int dist_int2, dist_dec2;

	ADS1115_readSingleEnded(ADS1115_MUX_AIN0, &sick0.rawMv);
	ADS1115_readSingleEnded(ADS1115_MUX_AIN1, &sick1.rawMv);
	ADS1115_readSingleEnded(ADS1115_MUX_AIN2, &sick2.rawMv);

	sick0.voltage = sick0.rawMv / 1000.0f;
	sick1.voltage = sick1.rawMv / 1000.0f;
	sick2.voltage = sick2.rawMv / 1000.0f;

	sick0.distCm = ((sick0.voltage - 0.19f) / 4.97f) * SICK_TOTAL_DIST_CM;
	sick1.distCm = ((sick1.voltage - 0.21f) / 4.96f) * SICK_TOTAL_DIST_CM;
	sick2.distCm = ((sick2.voltage - 0.36f) / 4.77f) * SICK_TOTAL_DIST_CM;

	dist_int0 = (int) dist0;
	dist_dec0 = (int) ((dist0 - dist_int0) * 10);     // 1 decimal place

	// Split floats into integer + decimal parts
	dist_int1 = (int) dist1;
	dist_dec1 = (int) ((dist1 - dist_int1) * 10);     // 1 decimal place

	// Split floats into integer + decimal parts
	dist_int2 = (int) dist2;
	dist_dec2 = (int) ((dist2 - dist_int2) * 10);     // 1 decimal place

	int len = snprintf(msg, sizeof(msg),
			" D0:%d.%d CM  ||   D1:%d.%d CM ||  D2:%d.%d CM\r\n", dist_int0,
			dist_dec0, dist_int1, dist_dec1, dist_int2, dist_dec2);
	HAL_UART_Transmit(&huart3, (uint8_t*) msg, len, HAL_MAX_DELAY);
}

void linearPIDCompute(float targetDist, float currentDist) {
	LinearPID.error = targetDist - currentDist;
	float deltaError = LinearPID.error - LinearPID.prev_error;
	LinearPID.prev_error = LinearPID.error;

	LinearPID.P = LinearPID.error * LinearPID.kp;

	LinearPID.I += LinearPID.error * dT * LinearPID.ki;

	if (dT > 0.0f) {
		LinearPID.D = (deltaError / dT) * LinearPID.kd;
	} else {
		LinearPID.D = 0.0f;
	}

	LinearPID.Output = LinearPID.P + LinearPID.I + LinearPID.D;
}

void MoveTo(float targetX, float targetY) {
	float targetDist = sqrtf(
			powf(targetX - Odom.xPosition, 2)
					+ powf(targetY - Odom.yPosition, 2));
	float angle = atan2f(targetY - Odom.yPosition, targetX - Odom.xPosition)
			- radians(IMU.target);

	linearPIDCompute(targetDist, 0.0f);  // error = remaining distance to target
	float vel = LinearPID.Output;

	float M1 = constrain(
			((vel * cosf(angle) - (CHASSIS_LENGTH * 0))) / CHASSIS_RADIUS,
			-LINEAR_PWM, LINEAR_PWM);
	float M2 = constrain(
			((sqrtf(3) * vel * sinf(angle) - vel * cosf(angle)
					- (2 * CHASSIS_LENGTH * 0)) / (2 * CHASSIS_RADIUS)),
			-LINEAR_PWM, LINEAR_PWM);
	float M3 =
			constrain(
					(-1
							* ((vel * cosf(angle) + sqrtf(3) * vel * sinf(angle)
									+ (2 * CHASSIS_LENGTH * 0))
									/ (2 * CHASSIS_RADIUS))), -LINEAR_PWM,
					LINEAR_PWM);

	ChassisCmd.pwm1 = (int) constrain(M1 + AngularPID.Output, -MAX_PWM,
			MAX_PWM);
	ChassisCmd.pwm2 = (int) constrain(M2 + AngularPID.Output, -MAX_PWM,
			MAX_PWM);
	ChassisCmd.pwm3 = (int) constrain(M3 + AngularPID.Output, -MAX_PWM,
			MAX_PWM);

	if (fabsf(LinearPID.error) < 3.0f) {
		NavFlags.reached = true;
	}
}

void NavigateTo() {
	if (!NavFlags.active
			|| NavFlags.index < 0|| NavFlags.index >= WAYPOINT_COUNT) {
		return;
	}

	getCurrentCoordinates();
	Odom.xPosition = sick1.distCm;
	Odom.yPosition = sick2.distCm;

	float targetX = WayPoints[Nav.index].x;
	float targetY = WayPoints[Nav.index].y;
	float targetHead = WayPoints[Nav.index].heading;

	if (!NavFlags.reached) {
		IMU.target = Nav.lockedHeading;
		AngularPIDCompute();
		MoveTo(targetX, targetY);
		ChassiMotorsRotate(ChassisCmd.pwm1, ChassisCmd.pwm2, ChassisCmd.pwm3);

		if (NavFlags.reached) {
			ChassiMotorsRotate(0, 0, 0);
		}

	} else if (!Nav.aligned) {
		// rotation phase — aim for final waypoint heading
		IMU.target = targetHead;
		AngularPIDCompute();

		ChassisCmd.pwm1 = (int) constrain(AngularPID.Output, -MAX_PWM, MAX_PWM);
		ChassisCmd.pwm2 = (int) constrain(AngularPID.Output, -MAX_PWM, MAX_PWM);
		ChassisCmd.pwm3 = (int) constrain(AngularPID.Output, -MAX_PWM, MAX_PWM);
		ChassiMotorsRotate(ChassisCmd.pwm1, ChassisCmd.pwm2, ChassisCmd.pwm3);

		if (fabsf(AngularPID.error) < 0.5f) {
			NavFlags.aligned = true;
			ChassiMotorsRotate(0, 0, 0);
		}
	}
}

void handleNavButton() {
	if (PS4.Cross && !NavButton.prevState) {
		NavButton.prevState = true;

		if (!NavFlags.active) {
			NavFlags.active = true;
			NavFlags.index = 0;

		} else if (Nav.aligned) {
			NavFlags.index++;

			if (NavFlags.index >= WAYPOINT_COUNT) {
				NavFlags.active = false;
				NavFlags.index = -1;
				ChassiMotorsRotate(0, 0, 0);
				return;
			}
		}

		NavFlags.reached = false;
		NavFlags.aligned = false;
		NavFlags.lockedHeading = IMU.current;

	} else if (!PS4.Cross) {
		NavButton.prevState = false;
	}
}

